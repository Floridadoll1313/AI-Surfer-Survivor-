{
  "version": 2,
  "rewrites": [
    { "source": "/dashboard-pink", "destination": "/index.html" },
    { "source": "/dashboard-blue", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/index.js" }
  ],
  "functions": {
    "index.js": {
      "includeFiles": "views/**/*.ejs"
    }
  }
}
